{
  "name": "@root/dumble",
  "private": true,
  "packageManager": "yarn@4.7.0",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "examples/*",
    "external/*",
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -b && node --import tsx packages/core/src/bin.ts",
    "lint": "eslint --cache",
    "test": "yarn build",
    "test:text": "shx rm -rf coverage && c8 -r text yarn test",
    "test:json": "shx rm -rf coverage && c8 -r json yarn test",
    "test:html": "shx rm -rf coverage && c8 -r html yarn test"
  },
  "devDependencies": {
    "@cordisjs/eslint-config": "^1.1.1",
    "@types/node": "^22.19.15",
    "c8": "^10.1.3",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.1",
    "shx": "^0.4.0",
    "tsx": "npm:@cordiverse/tsx@4.19.3-fix.3",
    "typescript": "^5.9.3"
  }
}
